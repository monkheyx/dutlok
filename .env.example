# Blizzard API credentials
# Create an application at https://develop.battle.net/
BLIZZARD_CLIENT_ID=your_client_id_here
BLIZZARD_CLIENT_SECRET=your_client_secret_here

# Region: us, eu, kr, tw
BLIZZARD_REGION=us

# Your guild info
GUILD_REALM=your-realm-slug
GUILD_NAME=your-guild-name

# Admin password for protected actions
ADMIN_PASSWORD=change_this_to_a_strong_password

# Database path (relative to project root)
DATABASE_PATH=./data/dutlok.db

# Sync schedule (cron expression) - default: every 6 hours
SYNC_CRON=0 */6 * * *

# App URL (for metadata)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=DUTLOK
